# ================================================================
# AI Karaoke Music Studio - Production Environment Variables
# ================================================================
# For Hugging Face Spaces: Add these as "Repository secrets"
# DO NOT commit .env file to version control
# DO NOT share SECRET_KEY publicly
# ================================================================

# ========================================
# FLASK CONFIGURATION (REQUIRED)
# ========================================

# Environment: development, production, testing
FLASK_ENV=production

# Secret key for session encryption (MUST be 32+ characters)
# Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
SECRET_KEY=your-secure-random-key-here-min-32-chars

# ========================================
# AUDIO PROCESSING
# ========================================

# Demucs model: htdemucs, htdemucs_ft, htdemucs_6s, mdx_extra, mdx_extra_q
DEMUCS_MODEL=htdemucs

# CPU threads for PyTorch processing
# HF Spaces: Use 2-4 (limited shared CPU)
# Local/Cloud: Use (CPU cores * 2)
TORCH_NUM_THREADS=2

# GPU acceleration (optional, auto-detected)
# Disabled for HF Spaces free tier (available if GPU tier requested)
# CUDA_VISIBLE_DEVICES=0

# ========================================
# FILE STORAGE
# ========================================

# Upload directory (will be created if doesn't exist)
UPLOAD_FOLDER=/app/uploads

# Projects directory
PROJECTS_FOLDER=/app/projects

# Maximum upload file size in MB
MAX_UPLOAD_SIZE=50

# ========================================
# FEATURES
# ========================================

# Enable YouTube URL downloads
ENABLE_YOUTUBE_DOWNLOAD=true

# Enable AI performance analysis
ENABLE_AI_ANALYSIS=true

# Enable cloud storage integration
ENABLE_CLOUD_STORAGE=false

# ========================================
# DATABASE
# ========================================

# SQLite database file path
DATABASE_FILE=karaoke_studio.db

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server host (0.0.0.0 for Docker)
FLASK_HOST=0.0.0.0

# Server port (for local dev only; Dockerfile uses 7860 for HF Spaces)
FLASK_PORT=5000

# Debug mode (never true in production)
DEBUG=false

# ========================================
# OPTIONAL: REVERSE PROXY
# ========================================

# If behind reverse proxy (e.g., Nginx)
PROXY_HOST=yourdomain.com
PROXY_SCHEME=https

# ========================================
# OPTIONAL: LOGGING
# ========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=info

# Log file path (HF Spaces: logs to stdout only)
LOG_FILE=/app/logs/app.log

# ================================================================
# HF SPACES SPECIFIC NOTES
# ================================================================
# 1. Port Configuration:
#    - Local dev: 5000 (from Flask)
#    - Docker/HF: 7860 (configured in Dockerfile)
#
# 2. CPU Threads:
#    - HF Spaces: 2 (shared CPU, limited resources)
#    - AWS/Cloud: 4-8 (dedicated instance)
#
# 3. Storage:
#    - HF: Ephemeral (~50GB, auto-cleanup 7 days)
#    - Local: Persistent (configure paths as needed)
#
# 4. Required Secrets (HF Spaces):
#    - FLASK_ENV
#    - SECRET_KEY (32+ chars)
#    - TORCH_NUM_THREADS
#    - DEMUCS_MODEL
#    - ENABLE_YOUTUBE_DOWNLOAD
#
# 5. Generate SECRET_KEY:
#    python3 -c "import secrets; print(secrets.token_hex(16))"
# ================================================================
