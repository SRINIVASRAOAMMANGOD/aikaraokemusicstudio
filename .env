# ========================================
# FLASK CONFIGURATION
# ========================================

# Environment: development, production, testing
FLASK_ENV=production

# Secret key for session encryption (GENERATE NEW FOR PRODUCTION)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dGhpc2lzYXNlY3VyZWtleWZvcnByb2R1Y3Rpb25jaGFuZ2VtZW5vdw==

# Debug mode (NEVER true in production)
DEBUG=false

# ========================================
# AUDIO PROCESSING
# ========================================

# Demucs model: htdemucs, htdemucs_ft, htdemucs_6s, mdx_extra, mdx_extra_q
DEMUCS_MODEL=htdemucs

# CPU threads for PyTorch processing (match your CPU cores)
TORCH_NUM_THREADS=4

# GPU acceleration (optional) - comment out if no GPU
# CUDA_VISIBLE_DEVICES=0

# ========================================
# FILE STORAGE
# ========================================

# Upload directory (will be created if doesn't exist)
UPLOAD_FOLDER=/app/uploads

# Projects directory
PROJECTS_FOLDER=/app/projects

# Maximum upload file size in MB
MAX_UPLOAD_SIZE=50

# Flask max content length in bytes (50MB = 52428800)
MAX_CONTENT_LENGTH=52428800

# ========================================
# FEATURES
# ========================================

# Enable YouTube URL downloads
ENABLE_YOUTUBE_DOWNLOAD=true

# Enable AI performance analysis
ENABLE_AI_ANALYSIS=true

# Enable cloud storage integration
ENABLE_CLOUD_STORAGE=false

# ========================================
# DATABASE
# ========================================

# SQLite database file path
DATABASE_FILE=karaoke_studio.db

# ========================================
# SERVER CONFIGURATION
# ========================================

# Server host (0.0.0.0 for Docker, 127.0.0.1 for localhost)
FLASK_HOST=0.0.0.0

# Server port
FLASK_PORT=5000

# ========================================
# LOGGING
# ========================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=info

# Log file path (optional - leave blank for stdout only)
# LOG_FILE=/app/logs/app.log

# ========================================
# SESSION CONFIGURATION
# ========================================

# HTTPS only (true for production with HTTPS)
SESSION_COOKIE_SECURE=true

# Prevent JavaScript access to cookies
SESSION_COOKIE_HTTPONLY=true

# CSRF protection: Lax, Strict, None
SESSION_COOKIE_SAMESITE=Lax

# ========================================
# OPTIONAL: REVERSE PROXY
# ========================================

# Domain name if behind reverse proxy (e.g., Nginx)
# PROXY_HOST=yourdomain.com

# Proxy scheme: http or https
# PROXY_SCHEME=https

# ========================================
# API CONFIGURATION
# ========================================

# Rate limiting: max requests per minute
API_MAX_REQUESTS_PER_MINUTE=60

# ========================================
# OPTIONAL: CLOUD STORAGE
# ========================================

# AWS S3 settings (if ENABLE_CLOUD_STORAGE=true)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=aikaraoke-bucket
# AWS_S3_REGION=us-east-1

# ========================================
# OPTIONAL: MODEL CACHE
# ========================================

# Pre-loaded model name for faster startup
# PRELOAD_MODEL=htdemucs

# Model cache directory
# MODEL_CACHE_DIR=/app/models
